digraph buffer_state_machine {
    rankdir=LR
    fontname="Helvetica"
    fontsize=11
    node [fontname="Helvetica" style=filled fontsize=10 shape=box margin="0.15,0.1"]
    edge [fontname="Helvetica" fontsize=8]
    nodesep=0.4
    ranksep=1.0
    compound=true

    // ===== Rotation distance feedback zones =====
    // The buffer stepper is synced to the extruder via shared trapq.
    // Each zone sets a rotation_distance multiplier:
    //   rd_new = base_rd / multiplier

    subgraph cluster_empty {
        label="EMPTY\nmult = 1 + safety_gain" labeljust=c fontsize=11 penwidth=2
        style="filled,rounded" color="#ea9999" fillcolor="#fce8e8"

        e_safety  [label=<SYNCED<BR/><FONT POINT-SIZE="8">mult 1.05 → deliver MORE</FONT>> fillcolor="#f4cccc"]
        e_escal   [label=<SYNCED<BR/><FONT POINT-SIZE="8">ESCALATED ×1.5</FONT>> fillcolor="#e06666"]
    }

    subgraph cluster_empty_middle {
        label="EMPTY_MIDDLE\nmult = 1 + drift_gain" labeljust=c fontsize=11 penwidth=2
        style="filled,rounded" color="#f9cb9c" fillcolor="#fef3e8"

        em_drift [label=<SYNCED<BR/><FONT POINT-SIZE="8">mult 1.02 → slight MORE</FONT>> fillcolor="#fce5cd"]
    }

    subgraph cluster_middle {
        label="MIDDLE (dead-band)\nmult = 1.00" labeljust=c fontsize=11 penwidth=2
        style="filled,rounded" color="#b6d7a8" fillcolor="#eaf5e6"

        m_neutral [label=<SYNCED<BR/><FONT POINT-SIZE="8">mult 1.00 → 1:1 follow</FONT>> fillcolor="#d9ead3"]
    }

    subgraph cluster_full_middle {
        label="FULL_MIDDLE\nmult = 1 − drift_gain" labeljust=c fontsize=11 penwidth=2
        style="filled,rounded" color="#f9cb9c" fillcolor="#fef3e8"

        fm_drift [label=<SYNCED<BR/><FONT POINT-SIZE="8">mult 0.98 → slight LESS</FONT>> fillcolor="#fce5cd"]
    }

    subgraph cluster_full {
        label="FULL\nmult = 1 − safety_gain" labeljust=c fontsize=11 penwidth=2
        style="filled,rounded" color="#ea9999" fillcolor="#fce8e8"

        f_safety [label=<SYNCED<BR/><FONT POINT-SIZE="8">mult 0.95 → deliver LESS</FONT>> fillcolor="#f4cccc"]
        f_escal  [label=<SYNCED<BR/><FONT POINT-SIZE="8">ESCALATED ×1.5</FONT>> fillcolor="#e06666"]
        f_retract [label=<RETRACT<BR/><FONT POINT-SIZE="8">unsync + force_move</FONT>> fillcolor="#cc0000" fontcolor=white]
    }

    ERROR [fillcolor="#f4cccc" label="ERROR"]

    // ===== Within-zone transitions (timing) =====

    e_safety -> e_escal  [label="fault_escalation\n_time elapsed"]
    e_escal  -> ERROR    [label="empty_safety\n_timeout" color="#cc0000"]

    f_safety -> f_escal  [label="fault_escalation\n_time elapsed"]
    f_escal  -> f_retract [label="full_safety\n_timeout" color="#cc0000"]

    // ===== Cross-zone transitions (sensor changes) =====

    e_safety -> em_drift  [label="empty\nclears" style=dashed]
    e_safety -> m_neutral [label="middle\ntriggers" style=dashed]

    em_drift -> e_safety  [label="empty\ntriggers" style=dashed]
    em_drift -> m_neutral [label="middle\ntriggers" style=dashed]

    m_neutral -> em_drift [label="middle\nclears" style=dashed]
    m_neutral -> fm_drift [label="full\ntriggers" style=dashed]

    fm_drift -> m_neutral [label="full\nclears" style=dashed]
    fm_drift -> f_safety  [label="middle\nclears" style=dashed]

    f_safety -> fm_drift  [label="middle\ntriggers" style=dashed]
    f_safety -> m_neutral [label="full clears +\nmiddle triggers" style=dashed]

    f_retract -> m_neutral [label="re-sync after\nretract" style=dashed]

    // ===== Sensor conflict =====

    e_safety -> ERROR [label="empty+full\nconflict" color="#cc0000" style=bold]
}
